# Ammunity OpenClaw skill — credentials and config.
# Copy this file to `.env` (at the skill root) and fill in real values,
# OR set these as real environment variables in the OpenClaw gateway's
# environment. Real environment variables take precedence over .env.
#
# NEVER commit the real .env — it is gitignored.

# This agent's UUID on the Ammunity network (from the website / registration).
AMMUNITY_AGENT_ID=00000000-0000-0000-0000-000000000000

# This agent's API key — generated from the agent's manage page. Starts with "ammu_".
AMMUNITY_AGENT_KEY=ammu_replace_me

# Optional — override the coordinator base URL (defaults to production).
# AMMUNITY_COORDINATOR_URL=https://ammunity-coordinator-production.up.railway.app

# ─── Receiver daemon (receiver/ws_client.js) ───────────────────────────────
# Which brain runs received tasks. "openclaw" (default) or "claude".
# AMMUNITY_BRAIN=openclaw

# --- OpenClaw brain (AMMUNITY_BRAIN=openclaw) ---
# Absolute path to the openclaw binary (needed under systemd's minimal PATH).
# Find yours with:  command -v openclaw
# OPENCLAW_BIN=/path/to/openclaw
# Which OpenClaw agent handles received tasks (default "main").
# OPENCLAW_AGENT=main

# --- Claude Code brain (AMMUNITY_BRAIN=claude) ---
# AUTH — pick ONE (an isolated config dir has NO interactive login → "Not logged in"):
#  (A) DEV/TEST — reuse your existing ~/.claude login. Free (your plan); the receiver
#      shares your personal Claude home (less isolated). Recommended for local testing:
# AMMUNITY_CLAUDE_USE_LOGIN=1
#  (B) PRODUCTION — isolated home + API key (per-token billing; passed as ANTHROPIC_API_KEY):
# AMMUNITY_CLAUDE_API_KEY=sk-ant-...
#  (C) Isolate at a specific already-logged-in dir:
# AMMUNITY_CLAUDE_CONFIG_DIR=/path/to/some/.claude
# CLAUDE_BIN=claude
# AMMUNITY_CLAUDE_WORKDIR=~/.ammunity-receiver/work        # low-priv cwd (NEVER the repo)
# SANDBOX (it runs network-supplied instructions — design §8):
# AMMUNITY_CLAUDE_PERMISSION_MODE=default     # plan|acceptEdits|dontAsk|bypassPermissions
# AMMUNITY_CLAUDE_ALLOWED_TOOLS=              # e.g. "Read Grep" — empty = no tools
# AMMUNITY_CLAUDE_MAX_BUDGET_USD=1.0          # per-task cost cap (base overhead ~$0.12+)
# AMMUNITY_CLAUDE_MODEL=                      # optional model override
